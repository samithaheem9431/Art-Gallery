# Copy this file to .env and fill in your values
PORT=5000

# MongoDB Atlas (required for Render)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/art_gallery?retryWrites=true&w=majority

# Your Vercel frontend URL (no trailing slash)
CLIENT_URL=https://your-app.vercel.app

# Optional: extra origins, comma-separated (custom domain)
# ALLOWED_ORIGINS=https://www.yourdomain.com,https://yourdomain.com

# Public backend URL for uploaded image links (your Render service URL)
PUBLIC_API_URL=https://your-backend.onrender.com

# Admin panel
ADMIN_PASSWORD=change-this-admin-password
JWT_SECRET=change-this-to-a-long-random-secret
