# Copy this file to .env and fill in your values
PORT=5000

# Local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/nk_art
# MongoDB Atlas (recommended for deployment) — replace <user>, <password>, cluster:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nk_art?retryWrites=true&w=majority

CLIENT_URL=http://localhost:3000

# Admin panel credentials
ADMIN_PASSWORD=change-this-admin-password
JWT_SECRET=change-this-to-a-long-random-secret
